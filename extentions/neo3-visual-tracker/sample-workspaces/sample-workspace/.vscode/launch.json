  "version": "0.2.0",
  "configurations": [
    {
      "name": "Change sample number",
      "type": "neo-contract",
      "request": "launch",
      "program": "${workspaceFolder}/Sample/bin/sc/SampleContract.nef",
      "invocation": {
        "operation": "changeNumber",
        "args": [42]
      }
    },
    {
      "name": "Read sample number",
      "type": "neo-contract",
      "request": "launch",
      "program": "${workspaceFolder}/Sample/bin/sc/SampleContract.nef",
      "invocation": {
        "operation": "getNumber"
      }
    }
  ]
}
